# ─────────────────────────────────────────────────────────────────────
#  .env.example — Plantilla de variables de entorno
# ─────────────────────────────────────────────────────────────────────
#  Copia este archivo a `.env` para desarrollo local:
#      cp .env.example .env
#  Luego rellena los valores reales.  NUNCA comitees `.env`.
#
#  En Render, configura estas variables desde:
#      Dashboard → Service → Environment → Add Environment Variable
# ─────────────────────────────────────────────────────────────────────

# ── Supabase (Auth + DB) ──────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Flask ─────────────────────────────────────────────────────────
FLASK_ENV=development
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-string-random-largo

# ── Playwright ────────────────────────────────────────────────────
# Local:  ~/.cache/ms-playwright  (default, no setear)
# Render: lo fija render.yaml
# PLAYWRIGHT_BROWSERS_PATH=

# ── Logs ──────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
